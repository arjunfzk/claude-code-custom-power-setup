{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Round 2/3 Critique Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_id",
    "round",
    "summary_judgment",
    "agreements_to_keep",
    "disagreements_with_state",
    "state_corrections",
    "surviving_ideas",
    "risks",
    "open_questions",
    "what_the_moderator_state_might_be_missing",
    "confidence"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "model_id": { "enum": ["M1", "M2", "M3"] },
    "round": { "enum": [2, 3] },
    "summary_judgment": { "type": "string" },
    "agreements_to_keep": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "disagreements_with_state": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "claim", "why_it_matters"],
        "properties": {
          "target": { "enum": ["moderator_state", "M1", "M2", "M3"] },
          "claim": { "type": "string" },
          "why_it_matters": { "type": "string" }
        }
      }
    },
    "state_corrections": {
      "type": "array",
      "items": { "type": "string" }
    },
    "surviving_ideas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "what_the_moderator_state_might_be_missing": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "confidence": { "enum": ["low", "medium", "high"] }
  }
}
