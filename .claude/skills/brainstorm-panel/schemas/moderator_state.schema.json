{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Moderator State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_summary",
    "user_goal",
    "hard_constraints",
    "available_models",
    "proposal_index",
    "agreement_points",
    "decision_axes",
    "conflicts",
    "minority_views",
    "open_questions",
    "risks",
    "what_the_moderator_state_might_be_missing"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "task_summary": { "type": "string" },
    "user_goal": { "type": "string" },
    "hard_constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "available_models": {
      "type": "array",
      "items": { "enum": ["M1", "M2", "M3"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "proposal_index": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "M1": { "$ref": "#/$defs/proposalIndexEntry" },
        "M2": { "$ref": "#/$defs/proposalIndexEntry" },
        "M3": { "$ref": "#/$defs/proposalIndexEntry" }
      }
    },
    "agreement_points": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourcedItem" }
    },
    "decision_axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axis", "why_it_matters", "positions"],
        "properties": {
          "axis": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "positions": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "M1": { "type": "string" },
              "M2": { "type": "string" },
              "M3": { "type": "string" }
            }
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "positions"],
        "properties": {
          "topic": { "type": "string" },
          "positions": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "M1": { "type": "string" },
              "M2": { "type": "string" },
              "M3": { "type": "string" }
            }
          }
        }
      }
    },
    "minority_views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "held_by", "why_it_might_matter"],
        "properties": {
          "text": { "type": "string" },
          "held_by": {
            "type": "array",
            "items": { "enum": ["M1", "M2", "M3"] },
            "minItems": 1
          },
          "why_it_might_matter": { "type": "string" }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourcedItem" }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "severity", "sources"],
        "properties": {
          "text": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high"] },
          "sources": {
            "type": "array",
            "items": { "enum": ["M1", "M2", "M3"] },
            "minItems": 1
          }
        }
      }
    },
    "what_the_moderator_state_might_be_missing": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourcedItem" }
    }
  },
  "$defs": {
    "proposalIndexEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "core_claim"],
      "properties": {
        "title": { "type": "string" },
        "core_claim": { "type": "string" }
      }
    },
    "sourcedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "sources"],
      "properties": {
        "text": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "enum": ["M1", "M2", "M3"] },
          "minItems": 1
        }
      }
    }
  }
}
